# Claude API — get yours at console.anthropic.com
ANTHROPIC_API_KEY=

# Notion integration token — get yours at notion.so/my-integrations
NOTION_TOKEN=

# Notion page/database IDs — filled automatically by `npm run setup`
NOTION_DAILY_SUMMARIES_PAGE_ID=
NOTION_JOB_TRACKER_DB_ID=

# Adzuna (optional but recommended — free at developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
